# Primary provider (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-4-70b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Failover provider (OpenRouter free-tier)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistral-small-3.1-24b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:8501
OPENROUTER_APP_NAME=Infinity-Chat

# Runtime
BACKEND_URL=http://127.0.0.1:8080
MAX_LOCAL_MEMORY=10
CONFIG_PATH=config.yaml

# Local persistent storage path (visible in project directory)
SQLITE_PATH=data/infinity_chat.db

# Network exposure (set host to 0.0.0.0 for LAN/Android access)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
UI_HOST=0.0.0.0
UI_PORT=8501
